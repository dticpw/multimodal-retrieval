# CLIP model path (local directory or HuggingFace model name)
CLIP_MODEL_PATH=E:/PG/model/clip

# Flickr30K dataset
FLICKR30K_IMAGE_DIR=E:/PG/dataset/flickr_30k/flickr30k-images
FLICKR30K_TRAIN_CSV=E:/PG/dataset/flickr_30k/train.csv
FLICKR30K_TRAIN4K_CSV=E:/PG/dataset/flickr_30k/train4K.csv
FLICKR30K_TEST_CSV=E:/PG/dataset/flickr_30k/test.csv

# Index and data storage
INDEX_DIR=indexes
DATA_DIR=data

# Encoding
BATCH_SIZE=64
DEVICE=cuda

# LLM (OpenAI-compatible API)
LLM_BASE_URL=https://your-proxy.example.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7
